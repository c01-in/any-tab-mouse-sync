{
  "manifest_version": 3,
  "name": "Any Tab Mouse Sync",
  "version": "0.1.0",
  "author": "Colin",
  "description": "Sync mouse actions between selected Chrome tabs.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "tabs", "storage", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Any Tab Mouse Sync",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/action16.png",
      "32": "icons/action32.png"
    }
  }
}
